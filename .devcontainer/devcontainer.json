{
  "image": "mcr.microsoft.com/devcontainers/go:1",
  "containerEnv": {
    "GOTOOLCHAIN": "auto"
  },
  "features": {
    "ghcr.io/devcontainers/features/hugo:1": {
      "extended": true,
      "version": "0.164.0"
    },
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "mhutchie.git-graph",
        "esbenp.prettier-vscode",
        "tamasfe.even-better-toml",
        "budparr.language-hugo-vscode"
      ]
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "git config --global core.autocrlf input && git config --global --add safe.directory ${containerWorkspaceFolder}",
  "postStartCommand": "nohup hugo server --renderToMemory --logLevel debug --disableFastRender --bind 0.0.0.0 -p 1313 > /tmp/hugo-server.log 2>&1 &",
  "forwardPorts": [
    1313
  ],
  "portsAttributes": {
    "1313": {
      "label": "Hugo preview",
      "onAutoForward": "openBrowser"
    }
  }
}
